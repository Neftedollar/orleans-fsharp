    <Compile Include="GrainStateTests.fs" />
    <Compile Include="SerializationProperties.fs" />
    <Compile Include="StateMachineProperties.fs" />
    <Compile Include="StreamingTests.fs" />
    <Compile Include="SiloConfigTests.fs" />
    <Compile Include="LoggingTests.fs" />
    <Compile Include="TestHarnessTests.fs" />
    <Compile Include="FsCheckIntegrationTests.fs" />
    <Compile Include="Benchmarks.fs" />
    <Compile Include="ReminderTests.fs" />
    <Compile Include="ReminderPersistenceProperties.fs" />
    <Compile Include="ReminderExceptionTests.fs" />
    <Compile Include="TimerTests.fs" />
    <Compile Include="ApiSurfaceV2Tests.fs" />
    <Compile Include="ObserverTests.fs" />
    <Compile Include="ReentrancyTests.fs" />
    <Compile Include="StatelessWorkerTests.fs" />
    <Compile Include="EventSourcingTests.fs" />
    <Compile Include="GrainArbitraryTests.fs" />
    <Compile Include="ServiceInjectionTests.fs" />
    <Compile Include="PlacementTests.fs" />
    <Compile Include="DeclarativeTimerTests.fs" />
    <Compile Include="PersistenceProviderTests.fs" />
    <Compile Include="FilterTests.fs" />
    <Compile Include="RequestCtxTests.fs" />
    <Compile Include="CancellationTokenTests.fs" />
    <Compile Include="AdditionalStateTests.fs" />
    <Compile Include="CompoundKeyTests.fs" />
    <Compile Include="OneWayTests.fs" />
    <Compile Include="BroadcastChannelTests.fs" />
    <Compile Include="AdvancedReentrancyTests.fs" />
    <Compile Include="AdvancedPlacementTests.fs" />
    <Compile Include="VersioningTests.fs" />
    <Compile Include="AnalyzerTests.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.*" />
    <PackageReference Include="FsCheck.Xunit" Version="3.*" />
    <PackageReference Include="Unquote" Version="7.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.*" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.*" />
    <PackageReference Include="Microsoft.Orleans.Runtime" Version="10.*" />
