<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <Version>0.8.0</Version>
    <PackageVersion>0.8.0</PackageVersion>
    <Authors>Orleans.FSharp Contributors</Authors>
    <Description>Idiomatic F# API for Microsoft Orleans</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Neftedollar/orleans-fsharp</PackageProjectUrl>
    <PackageTags>fsharp;orleans;actors;distributed;grains</PackageTags>
    <RepositoryUrl>https://github.com/Neftedollar/orleans-fsharp</RepositoryUrl>
    <IsPackable>true</IsPackable>
  </PropertyGroup>
</Project>
